# app/.env.example  ← закоммитить в репо
LLM_PROVIDER=gigachat          # lm_studio | gigachat | openrouter | mock

# GigaChat
GIGACHAT_CREDENTIALS=          # base64(ClientID:ClientSecret) из personal.sber.ru
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat

# OpenRouter (когда перейдёшь)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# LM Studio (локальный)
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL=local-model